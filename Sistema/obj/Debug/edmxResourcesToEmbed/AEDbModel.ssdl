    [Evento].[nombre_clie] AS [nombre_clie], 
    [Evento].[NombreDifunto] AS [NombreDifunto], 
    [Evento].[idSala] AS [idSala], 
    [Evento].[Sala] AS [Sala], 
    [Evento].[DireccionVel] AS [DireccionVel], 
    [Evento].[DireccionVel2] AS [DireccionVel2], 
    [Evento].[FechaVel] AS [FechaVel], 
