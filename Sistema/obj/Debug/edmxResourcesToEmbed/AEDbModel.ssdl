    <EntitySet Name="Evento" EntityType="Self.Evento" store:Type="Tables" store:Schema="dbo">
      <DefiningQuery>SELECT 
    [Evento].[idline] AS [idline], 
    [Evento].[num_Doc] AS [num_Doc], 
