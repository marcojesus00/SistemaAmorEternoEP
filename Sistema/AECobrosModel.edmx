        <EntityContainer Name="AECobrosModelStoreContainer">
          <EntitySet Name="CLIENTESOLD" EntityType="Self.CLIENTESOLD" Schema="dbo" store:Type="Tables" />
          <EntitySet Name="CONTRATO1" EntityType="Self.CONTRATO1" Schema="dbo" store:Type="Tables" />
