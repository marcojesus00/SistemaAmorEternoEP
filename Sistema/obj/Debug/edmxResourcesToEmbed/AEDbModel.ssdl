    <EntitySet Name="ClientesH1" EntityType="Self.ClientesH1" store:Type="Tables" store:Schema="dbo">
      <DefiningQuery>SELECT 
    [ClientesH1].[id] AS [id], 
    [ClientesH1].[Codigo_clie] AS [Codigo_clie], 
    [ClientesH1].[Nombre_clie] AS [Nombre_clie], 
    [ClientesH1].[correoEnvio] AS [correoEnvio], 
    [ClientesH1].[TelefonoEnvio] AS [TelefonoEnvio], 
    [ClientesH1].[tipo] AS [tipo], 
    [ClientesH1].[SolicitadoPor] AS [SolicitadoPor], 
    [ClientesH1].[usuario] AS [usuario], 
    [ClientesH1].[Fechasys] AS [Fechasys], 
    [ClientesH1].[Hora] AS [Hora], 
    [ClientesH1].[estatus] AS [estatus], 
    [ClientesH1].[Imprimir] AS [Imprimir], 
    [ClientesH1].[cl_cobrador] AS [cl_cobrador], 
    [ClientesH1].[Comentarios] AS [Comentarios]
    FROM [dbo].[ClientesH1] AS [ClientesH1]</DefiningQuery>
    </EntitySet>
    <EntitySet Name="ClientesH3" EntityType="Self.ClientesH3" store:Type="Tables" store:Schema="dbo">
