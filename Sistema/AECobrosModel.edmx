          <EntitySet Name="AE_CZONA" EntityType="Self.AE_CZONA" store:Type="Tables" store:Schema="dbo">
            <DefiningQuery>SELECT 
    [AE_CZONA].[Cod_zona] AS [Cod_zona], 
    [AE_CZONA].[Nombre_zona] AS [Nombre_zona], 
    [AE_CZONA].[E_ZONAS] AS [E_ZONAS], 
    [AE_CZONA].[E_VENTAS] AS [E_VENTAS], 
    [AE_CZONA].[E_DEVOLUC] AS [E_DEVOLUC], 
    [AE_CZONA].[E_VENTAS2] AS [E_VENTAS2], 
    [AE_CZONA].[ZON_NC] AS [ZON_NC], 
    [AE_CZONA].[ZON_ND] AS [ZON_ND], 
    [AE_CZONA].[descri_zona] AS [descri_zona], 
    [AE_CZONA].[E_CAJA] AS [E_CAJA], 
    [AE_CZONA].[E_APARTA] AS [E_APARTA], 
    [AE_CZONA].[E_LETRAS] AS [E_LETRAS], 
    [AE_CZONA].[E_PRIMA] AS [E_PRIMA], 
    [AE_CZONA].[E_PAQUETE] AS [E_PAQUETE], 
    [AE_CZONA].[E_CXC] AS [E_CXC], 
    [AE_CZONA].[E_CONTADO] AS [E_CONTADO], 
    [AE_CZONA].[E_RTN] AS [E_RTN]
    FROM [dbo].[AE_CZONA] AS [AE_CZONA]</DefiningQuery>
          </EntitySet>
          <EntitySet Name="Almacen" EntityType="Self.Almacen" store:Type="Tables" store:Schema="dbo">
            <DefiningQuery>SELECT 
    [Almacen].[DocEntry] AS [DocEntry], 
    [Almacen].[Codigo] AS [Codigo], 
    [Almacen].[Descripcion] AS [Descripcion], 
    [Almacen].[Estado] AS [Estado]
    FROM [dbo].[Almacen] AS [Almacen]</DefiningQuery>
          </EntitySet>
          <EntitySet Name="Articulo" EntityType="Self.Articulo" store:Type="Tables" store:Schema="dbo">
            <DefiningQuery>SELECT 
    [Articulo].[DocEntry] AS [DocEntry], 
    [Articulo].[Codigo] AS [Codigo], 
    [Articulo].[Descripcion] AS [Descripcion], 
    [Articulo].[Marca] AS [Marca], 
    [Articulo].[Modelo] AS [Modelo]
    FROM [dbo].[Articulo] AS [Articulo]</DefiningQuery>
          </EntitySet>
          <EntitySet Name="EstadisticaVisitasDetalle" EntityType="Self.EstadisticaVisitasDetalle" store:Type="Tables" store:Schema="dbo">
            <DefiningQuery>SELECT 
    [EstadisticaVisitasDetalle].[Codigo Cliente] AS [Codigo Cliente], 
    [EstadisticaVisitasDetalle].[Nombre Cliente] AS [Nombre Cliente], 
    [EstadisticaVisitasDetalle].[Saldo Actual] AS [Saldo Actual], 
    [EstadisticaVisitasDetalle].[Cobrado] AS [Cobrado], 
    [EstadisticaVisitasDetalle].[Primer Visita] AS [Primer Visita], 
    [EstadisticaVisitasDetalle].[Ultima Visita] AS [Ultima Visita], 
    [EstadisticaVisitasDetalle].[Ultimo Cobro] AS [Ultimo Cobro], 
    [EstadisticaVisitasDetalle].[Recibos] AS [Recibos], 
    [EstadisticaVisitasDetalle].[Visitados] AS [Visitados], 
    [EstadisticaVisitasDetalle].[Cobrador] AS [Cobrador], 
    [EstadisticaVisitasDetalle].[Lider] AS [Lider], 
    [EstadisticaVisitasDetalle].[Zona] AS [Zona]
    FROM [dbo].[EstadisticaVisitasDetalle] AS [EstadisticaVisitasDetalle]</DefiningQuery>
          </EntitySet>
          <EntitySet Name="LogProcesados" EntityType="Self.LogProcesados" store:Type="Tables" store:Schema="dbo">
            <DefiningQuery>SELECT 
    [LogProcesados].[IdLine] AS [IdLine], 
    [LogProcesados].[Usuario] AS [Usuario], 
    [LogProcesados].[Fecha] AS [Fecha], 
    [LogProcesados].[Hora] AS [Hora], 
    [LogProcesados].[CodGestor] AS [CodGestor], 
    [LogProcesados].[Liquida] AS [Liquida], 
    [LogProcesados].[TotalProcesado] AS [TotalProcesado]
    FROM [dbo].[LogProcesados] AS [LogProcesados]</DefiningQuery>
          </EntitySet>
          <EntitySet Name="MovArticulo" EntityType="Self.MovArticulo" store:Type="Tables" store:Schema="dbo">
            <DefiningQuery>SELECT 
    [MovArticulo].[DocEntry] AS [DocEntry], 
    [MovArticulo].[Fecha] AS [Fecha], 
