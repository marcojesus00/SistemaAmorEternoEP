    [Evento].[Hora] AS [Hora], 
    [Evento].[FechaSys] AS [FechaSys], 
    [Evento].[HoraSys] AS [HoraSys], 
    [Evento].[Sepelio] AS [Sepelio], 
    [Evento].[FechaSepelio] AS [FechaSepelio], 
    [Evento].[DireccionSep] AS [DireccionSep], 
    [Evento].[DireccionSep2] AS [DireccionSep2], 
    [Evento].[HoraSepelio] AS [HoraSepelio], 
    [Evento].[Activo] AS [Activo], 
    [Evento].[Estatus] AS [Estatus], 
    [Evento].[Telefono] AS [Telefono], 
    [Evento].[Sucursal] AS [Sucursal], 
    [Evento].[usuariosys] AS [usuariosys], 
    [Evento].[fechaestatus] AS [fechaestatus], 
    [Evento].[usuarioestatus] AS [usuarioestatus], 
    [Evento].[img1] AS [img1], 
